# 默认 mock，不调用真实模型，不产生费用。
MODEL_PROVIDER=mock

# 拿到 OpenRouter Key 后再打开：
# MODEL_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...

# 可选：指定 OpenRouter 图片模型。不填时默认 openai/gpt-image-1。
# OPENROUTER_IMAGE_MODEL=openai/gpt-image-1

# 可选：OpenRouter attribution。
# OPENROUTER_SITE_URL=http://127.0.0.1:4317

# 后续接 DeepSeek 做 prompt / 家具清单时再填：
# DEEPSEEK_API_KEY=sk-...
