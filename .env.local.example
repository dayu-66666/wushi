# 默认 mock，不调用真实模型，不产生费用。
MODEL_PROVIDER=mock

# ===== 当前主链路：FLUX Kontext 编辑（fal） =====
# MODEL_PROVIDER=fal_kontext
# FAL_KEY=key_id:key_secret
# 可选覆盖：
# FAL_EDIT_MODEL=fal-ai/flux-pro/kontext
# FAL_EDIT_GUIDANCE=4.5
# ENABLE_MULTI_REFERENCE=true   # 慎开：双图 Kontext 有结构漂移风险

# ===== 可切换图像编辑模型（A/B 测试用，参考图直接进模型） =====
# MODEL_PROVIDER=fal_image_edit
# FAL_IMAGE_EDIT_MODEL=fal-ai/nano-banana/edit      # 谷歌 nano-banana
# FAL_IMAGE_EDIT_MODEL=openai/gpt-image-2/edit      # OpenAI GPT Image 2
# GPT_IMAGE_QUALITY=high                            # gpt-image 专用：auto/low/medium/high

# ===== 视觉分析与质检（房间分析、风格提取、质检、翻译） =====
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_VISION_MODEL=qwen/qwen3-vl-32b-instruct
# OPENROUTER_SITE_URL=http://127.0.0.1:4317

# ===== 可选文本模型 =====
# TEXT_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
